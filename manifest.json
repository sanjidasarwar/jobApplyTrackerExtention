{
  "manifest_version": 3,
  "name": "Job Apply Tracker",
  "version": "1.0",
  "description": "Track your job applications easily",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
